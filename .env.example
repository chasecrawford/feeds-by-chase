# ---- Service identity (did:web on your own domain) ----
# The hostname where this service is reachable over HTTPS.
# Example: feeds.example.com  (NOT including https://)
FEEDGEN_HOSTNAME=feeds.example.com

# Service DID. For did:web this is literally "did:web:" + FEEDGEN_HOSTNAME.
FEEDGEN_SERVICE_DID=did:web:feeds.example.com

# The account (repo) that owns the published feed records — your own DID.
# Only used to build correct feed URIs in describeFeedGenerator.
FEEDGEN_PUBLISHER_DID=did:plc:youraccountdid

# ---- Local server ----
# Port the service listens on locally (Caddy forwards 443 -> this).
FEEDGEN_PORT=3020

# Interface to bind. Default 127.0.0.1 (localhost-only) so only the local
# reverse proxy can reach it. Use 0.0.0.0 only to expose the service directly.
FEEDGEN_BIND=127.0.0.1

# Where to keep the SQLite database file.
SQLITE_PATH=./feed.sqlite

# ---- Firehose / ingestion ----
# Jetstream endpoint (lightweight JSON firehose). Pick the one nearest you.
#   wss://jetstream1.us-east.bsky.network/subscribe
#   wss://jetstream2.us-east.bsky.network/subscribe
#   wss://jetstream1.us-west.bsky.network/subscribe
#   wss://jetstream2.us-west.bsky.network/subscribe
JETSTREAM_ENDPOINT=wss://jetstream2.us-east.bsky.network/subscribe

# How many days of matching posts to keep before pruning (keeps the DB small).
RETENTION_DAYS=7

# ---- Publishing only (used by `npm run publish`) ----
# Your Bluesky handle and an APP PASSWORD (Settings -> App Passwords, NOT your main password).
BLUESKY_HANDLE=you.example.com
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

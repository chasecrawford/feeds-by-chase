{
  "name": "louisville-bsky-feed",
  "version": "0.1.0",
  "description": "Self-hosted Bluesky keyword feed generator (replacement for SkyFeed feeds)",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "serve": "node dist/src/index.js",
    "publish": "tsx scripts/publish.ts",
    "unpublish": "tsx scripts/unpublish.ts",
    "backfill": "tsx scripts/backfill.ts",
    "revalidate": "tsx scripts/revalidate.ts"
  },
  "dependencies": {
    "@atproto/api": "^0.13.18",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
